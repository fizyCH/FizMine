# FizMine Panel Configuration
# Copy this file to .env and edit

# Minecraft server directory
MC_DIR=/minecraft

# Panel web port
PANEL_PORT=8080

# Java executable path (optional, auto-detected if not set)
# Windows example: JAVA_PATH=C:\Program Files\Eclipse Adoptium\jdk-17.0.8.7-hotspot\bin\java.exe
# Linux example: JAVA_PATH=/usr/lib/jvm/java-17-openjdk/bin/java
# JAVA_PATH=

# Java arguments (optional, default: -Xmx2G -Xms1G)
# JAVA_ARGS=-Xmx4G -Xms2G

# Panel language: en, ru, de
PANEL_LANG=en

# Server console encoding (optional, auto-detected if not set)
# Windows Russian: JAVA_ENCODING=cp1251
# Windows English: JAVA_ENCODING=cp1252
# Linux/Modern: leave empty for auto-detect (utf-8 first)
# JAVA_ENCODING=
